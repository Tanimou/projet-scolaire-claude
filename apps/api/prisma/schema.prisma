// =============================================================================
// Pilotage Scolaire — Prisma schema (Phase 0 — fondations)
// Postgres 15 + RLS (configurée séparément via migration SQL)
// =============================================================================

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [uuidOssp(map: "uuid-ossp"), citext, pgTrgm(map: "pg_trgm"), pgcrypto, btreeGin(map: "btree_gin")]
}

// ---------------------------------------------------------------------------
// Enums
// ---------------------------------------------------------------------------
enum TenantStatus {
  active
  suspended
  archived
}

enum SchoolStatus {
  active
  closed
}

enum UserStatus {
  active
  suspended
  deleted
}

enum Portal {
  admin
  teacher
  parent
}

enum AcademicYearStatus {
  active
  closed
  archived
}

enum ClassStatus {
  active
  closed
}

enum StudentStatus {
  active
  transferred
  graduated
  withdrawn
}

enum ImportType {
  students
  classes
  subjects
  teachers
  parents
  enrollments
  grades
  attendance
}

enum ImportStatus {
  uploaded
  validating
  validated
  queued
  applying
  applied
  failed
  rolled_back
}

enum ImportMode {
  all_or_nothing
  skip_invalid
}

enum ImportRowStatus {
  pending
  valid
  invalid
  applied
  skipped
  rolled_back
}

/// E11-S2 — reconciliation classification (ADR-024 §reconciliation).
/// Orthogonal to ImportRowStatus (which answers "did the pipeline process the
/// row"); this answers "what did the upsert actually do" so the import becomes
/// auditable/reversible. created = new entity; updated = matched + a
/// non-protected field changed; unchanged = matched, nothing to apply (the
/// idempotency anchor — a re-run converges here, never a duplicate created);
/// conflict = a matched protected field disagrees → blocked, recorded in
/// ImportRow.conflictFields, NO write; skipped = invalid/filtered, no entity.
enum ReconciliationClass {
  created
  updated
  unchanged
  conflict
  skipped
}

/// E11-S3 — provenance discriminator on an ImportBatch. Nullable + defaulted
/// `csv_upload` ⇒ every existing batch reads as a human CSV upload (zero
/// behaviour change); a OneRoster-pulled batch carries `oneroster`.
enum ImportOrigin {
  csv_upload
  oneroster
}

/// E11-S3 — the kind of roster source an admin connects. `oneroster_csv` = an
/// uploaded OneRoster v1.1 CSV bundle (students/classes/enrollments); the REST
/// variant is the optional stretch (the model admits it without a rewrite).
enum RosterSourceKind {
  oneroster_csv
  oneroster_rest
}

/// E11-S3 — the sync lifecycle of a RosterSource. `mapped` = pulled + mapped
/// into a validated ImportBatch, awaiting the admin's apply (S1 async spine).
enum RosterSyncStatus {
  idle
  pulling
  mapped
  failed
}

enum CalendarEventType {
  vacation_break
  public_holiday
  exam_period
  meeting
  ceremony
  pedagogical_day
  custom
}

enum CalendarEventScope {
  school_wide
  cycle_scope
  grade_level_scope
  class_section_scope
}

enum CalendarEventVisibility {
  all
  staff_only
  admin_only
}

enum GuardianRelationship {
  mother
  father
  legal_guardian
  grandparent
  sibling
  other
}

enum GuardianshipStatus {
  pending
  active
  revoked
}

enum EnrollmentStatus {
  pending
  active
  transferred_in
  transferred_out
  graduated
  dropped
}

// ---------------------------------------------------------------------------
// Phase 4 — teaching + assessments + grades
// ---------------------------------------------------------------------------
enum AssessmentKind {
  written_test
  oral
  homework
  project
  participation
  practical
  other
}

enum GradeStatus {
  draft
  published
  revised
}

/// Rôle d'un enseignant sur une affectation (classe × matière).
/// Deux modèles d'affectation cohabitent :
///   - primaire/maternelle : un instituteur `principal` + un ou des `assistant`s ;
///   - collège/lycée : un `subject_teacher` (prof) par matière.
/// Règle de synchro : `principal` ⇔ `isMainTeacher = true` (un seul par classe).
enum AssignmentRole {
  principal
  assistant
  subject_teacher
}

// ---------------------------------------------------------------------------
// Phase 5 — sessions, cahier de texte, attendance, announcements
// ---------------------------------------------------------------------------
enum AttendanceStatus {
  present
  absent
  absent_excused
  late
  left_early
}

enum LessonStatus {
  draft
  published
}

enum AnnouncementScope {
  school_wide
  cycle_scope
  grade_level_scope
  class_section_scope
  individual_student
  individual_user
}

enum AnnouncementPriority {
  normal
  high
  urgent
}

// ---------------------------------------------------------------------------
// Tenancy
// ---------------------------------------------------------------------------
model Tenant {
  id        String       @id @default(uuid()) @db.Uuid
  name      String
  slug      String       @unique
  status    TenantStatus @default(active)
  plan      String       @default("standard")
  settings  Json         @default("{}")
  createdAt DateTime     @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime     @updatedAt @map("updated_at") @db.Timestamptz(6)

  schools      School[]
  userProfiles UserProfile[]

  @@map("tenant")
}

model School {
  id         String       @id @default(uuid()) @db.Uuid
  tenantId   String       @map("tenant_id") @db.Uuid
  name       String
  schoolCode String       @unique @map("school_code")
  address    Json?
  country    String       @db.Char(2)
  timezone   String       @default("Europe/Paris")
  locale     String       @default("fr-FR")
  status     SchoolStatus @default(active)
  createdAt  DateTime     @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt  DateTime     @updatedAt @map("updated_at") @db.Timestamptz(6)

  tenant          Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  branding        Branding?
  academicYears   AcademicYear[]
  cycles          Cycle[]
  gradeLevels     GradeLevel[]
  subjects        Subject[]
  students        Student[]
  guardians       Guardian[]
  teacherProfiles TeacherProfile[]
  importBatches   ImportBatch[]
  rosterSources   RosterSource[]
  calendarEvents  CalendarEvent[]
  announcements   Announcement[]
  // E7 — remediation & tutoring catalogue (additive back-relations).
  tutors              Tutor[]
  tutorAvailabilities TutorAvailability[]

  @@index([tenantId])
  @@map("school")
}

// ---------------------------------------------------------------------------
// School structure
// ---------------------------------------------------------------------------

/// A school year (e.g. "2025-2026"). A school can have many; typically one is active.
model AcademicYear {
  id        String             @id @default(uuid()) @db.Uuid
  tenantId  String             @map("tenant_id") @db.Uuid
  schoolId  String             @map("school_id") @db.Uuid
  name      String
  startDate DateTime           @map("start_date") @db.Date
  endDate   DateTime           @map("end_date") @db.Date
  status    AcademicYearStatus @default(active)
  createdAt DateTime           @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime           @updatedAt @map("updated_at") @db.Timestamptz(6)

  school              School               @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  terms               Term[]
  classSections       ClassSection[]
  enrollments         Enrollment[]
  calendarEvents      CalendarEvent[]
  teachingAssignments TeachingAssignment[]

  @@unique([schoolId, name])
  @@index([tenantId, schoolId])
  @@map("academic_year")
}

/// A teaching period inside an academic year — trimester or semester.
model Term {
  id             String   @id @default(uuid()) @db.Uuid
  tenantId       String   @map("tenant_id") @db.Uuid
  academicYearId String   @map("academic_year_id") @db.Uuid
  name           String
  orderIndex     Int      @map("order_index")
  startDate      DateTime @map("start_date") @db.Date
  endDate        DateTime @map("end_date") @db.Date
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  academicYear AcademicYear @relation(fields: [academicYearId], references: [id], onDelete: Cascade)
  assessments  Assessment[]

  @@unique([academicYearId, orderIndex])
  @@unique([academicYearId, name])
  @@index([tenantId])
  @@map("term")
}

/// Pedagogical cycle (Maternelle, Primaire, Collège, Lycée, etc.).
model Cycle {
  id         String   @id @default(uuid()) @db.Uuid
  tenantId   String   @map("tenant_id") @db.Uuid
  schoolId   String   @map("school_id") @db.Uuid
  code       String
  name       String
  orderIndex Int      @map("order_index")
  color      String?
  icon       String?
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  school         School          @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  gradeLevels    GradeLevel[]
  calendarEvents CalendarEvent[]
  announcements  Announcement[]

  @@unique([schoolId, code])
  @@index([tenantId, schoolId])
  @@map("cycle")
}

/// A grade level inside a cycle (6e, 5e, Terminale, etc.). Ordered.
model GradeLevel {
  id         String   @id @default(uuid()) @db.Uuid
  tenantId   String   @map("tenant_id") @db.Uuid
  schoolId   String   @map("school_id") @db.Uuid
  cycleId    String   @map("cycle_id") @db.Uuid
  code       String
  name       String
  orderIndex Int      @map("order_index")
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  school         School               @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  cycle          Cycle                @relation(fields: [cycleId], references: [id], onDelete: Restrict)
  classSections  ClassSection[]
  coefficients   SubjectCoefficient[]
  calendarEvents CalendarEvent[]
  announcements  Announcement[]

  @@unique([schoolId, code])
  @@index([tenantId, schoolId])
  @@index([cycleId])
  @@map("grade_level")
}

/// A teaching subject (Mathématiques, Français, Histoire-Géo, etc.).
model Subject {
  id                 String   @id @default(uuid()) @db.Uuid
  tenantId           String   @map("tenant_id") @db.Uuid
  schoolId           String   @map("school_id") @db.Uuid
  code               String
  name               String
  defaultCoefficient Decimal  @default(1.0) @map("default_coefficient") @db.Decimal(4, 2)
  color              String?
  icon               String?
  active             Boolean  @default(true)
  createdAt          DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  school              School               @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  coefficients        SubjectCoefficient[]
  teachingAssignments TeachingAssignment[]
  alertInstances      AlertInstance[]
  meetingRequests     MeetingRequest[]
  conversations       Conversation[]
  // E7 — remediation plans targeting this subject (additive back-relation).
  remediationPlans    RemediationPlan[]

  @@unique([schoolId, code])
  @@index([tenantId, schoolId])
  @@map("subject")
}

/// Coefficient override per (grade level × subject). If absent, fall back to Subject.defaultCoefficient.
model SubjectCoefficient {
  id           String   @id @default(uuid()) @db.Uuid
  tenantId     String   @map("tenant_id") @db.Uuid
  gradeLevelId String   @map("grade_level_id") @db.Uuid
  subjectId    String   @map("subject_id") @db.Uuid
  coefficient  Decimal  @db.Decimal(4, 2)
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  gradeLevel GradeLevel @relation(fields: [gradeLevelId], references: [id], onDelete: Cascade)
  subject    Subject    @relation(fields: [subjectId], references: [id], onDelete: Cascade)

  @@unique([gradeLevelId, subjectId])
  @@index([tenantId])
  @@map("subject_coefficient")
}

/// A class section for a given academic year + grade level (e.g. "6eA" in 2025-2026).
model ClassSection {
  id             String      @id @default(uuid()) @db.Uuid
  tenantId       String      @map("tenant_id") @db.Uuid
  academicYearId String      @map("academic_year_id") @db.Uuid
  gradeLevelId   String      @map("grade_level_id") @db.Uuid
  name           String
  maxStudents    Int         @default(30) @map("max_students")
  room           String?
  color          String?
  icon           String?
  options        Json?
  internalNotes  String?     @map("internal_notes")
  status         ClassStatus @default(active)
  createdAt      DateTime    @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime    @updatedAt @map("updated_at") @db.Timestamptz(6)

  academicYear        AcademicYear         @relation(fields: [academicYearId], references: [id], onDelete: Cascade)
  gradeLevel          GradeLevel           @relation(fields: [gradeLevelId], references: [id], onDelete: Restrict)
  enrollments         Enrollment[]
  calendarEvents      CalendarEvent[]
  teachingAssignments TeachingAssignment[]
  announcements       Announcement[]
  alertInstances      AlertInstance[]

  @@unique([academicYearId, gradeLevelId, name])
  @@index([tenantId])
  @@map("class_section")
}

// ---------------------------------------------------------------------------
// Students (minimal — full enrollment/guardianship wires up in Phase 3)
// ---------------------------------------------------------------------------

/// A student enrolled (or about to be) in the school.
model Student {
  id           String        @id @default(uuid()) @db.Uuid
  tenantId     String        @map("tenant_id") @db.Uuid
  schoolId     String        @map("school_id") @db.Uuid
  firstName    String        @map("first_name")
  lastName     String        @map("last_name")
  birthDate    DateTime?     @map("birth_date") @db.Date
  externalRef  String?       @map("external_ref")
  email        String?
  phone        String?
  gender       String?       @db.Char(1)
  nationality  String?       @db.Char(2)
  address      Json?
  photoUrl     String?       @map("photo_url")
  medicalNotes String?       @map("medical_notes")
  status       StudentStatus @default(active)
  notes        String?
  customFields Json          @default("{}") @map("custom_fields")
  // E8-S1 — the learner's login link (additive, nullable, @unique). One pupil ↔
  // one `student`-role account (the Guardian.userProfileId precedent). Severable
  // without data loss (onDelete: SetNull); existing rows stay null until an admin
  // provisions the account, so the change is expand-only (no backfill). See
  // docs/adr/ADR-021-student-role-and-self-abac.md.
  userProfileId String?       @unique @map("user_profile_id") @db.Uuid
  createdAt    DateTime      @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime      @updatedAt @map("updated_at") @db.Timestamptz(6)

  school            School             @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  // E8-S1 — the linked learner login (1:1, additive). Named relation avoids any
  // collision with the other Student↔* relations.
  userProfile       UserProfile?       @relation("StudentAccount", fields: [userProfileId], references: [id], onDelete: SetNull)
  guardianships     Guardianship[]
  enrollments       Enrollment[]
  grades            Grade[]
  attendanceRecords AttendanceRecord[]
  announcements     Announcement[]
  alertInstances    AlertInstance[]
  meetingRequests   MeetingRequest[]
  conversations     Conversation[]
  // E7 — remediation plans + bookings for this student (additive back-relations).
  remediationPlans  RemediationPlan[]
  bookings          Booking[]
  // E9-S1 — guardianship-claims whose matcher resolved to THIS student (additive).
  claims            GuardianshipClaim[] @relation("ClaimMatchedStudent")

  @@unique([schoolId, externalRef])
  @@index([tenantId, schoolId])
  @@index([lastName, firstName])
  @@map("student")
}

/// A guardian (parent, legal guardian, etc.). May be linked to a UserProfile (parent portal user) or not.
model Guardian {
  id            String   @id @default(uuid()) @db.Uuid
  tenantId      String   @map("tenant_id") @db.Uuid
  schoolId      String   @map("school_id") @db.Uuid
  userProfileId String?  @unique @map("user_profile_id") @db.Uuid
  firstName     String   @map("first_name")
  lastName      String   @map("last_name")
  email         String?  @db.Citext
  phone         String?
  profession    String?
  address       Json?
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt     DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  school        School         @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  userProfile   UserProfile?   @relation(fields: [userProfileId], references: [id], onDelete: SetNull)
  guardianships Guardianship[]
  // E9-S1 — the parent's self-service child-claims (additive back-relation array).
  claims        GuardianshipClaim[]

  @@index([tenantId, schoolId])
  @@index([lastName, firstName])
  @@index([email])
  @@map("guardian")
}

/// Link Guardian ↔ Student with relationship metadata.
model Guardianship {
  id               String               @id @default(uuid()) @db.Uuid
  tenantId         String               @map("tenant_id") @db.Uuid
  guardianId       String               @map("guardian_id") @db.Uuid
  studentId        String               @map("student_id") @db.Uuid
  relationship     GuardianRelationship
  isPrimaryContact Boolean              @default(false) @map("is_primary_contact")
  canPickup        Boolean              @default(true) @map("can_pickup")
  hasLegalCustody  Boolean              @default(true) @map("has_legal_custody")
  status           GuardianshipStatus   @default(active)
  approvedBy       String?              @map("approved_by") @db.Uuid
  approvedAt       DateTime?            @map("approved_at") @db.Timestamptz(6)
  revokedAt        DateTime?            @map("revoked_at") @db.Timestamptz(6)
  notes            String?
  createdAt        DateTime             @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt        DateTime             @updatedAt @map("updated_at") @db.Timestamptz(6)

  guardian Guardian @relation(fields: [guardianId], references: [id], onDelete: Cascade)
  student  Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  // E9-S1 — the claim this link was driven by, if any (additive, 1:1 back-relation).
  claim    GuardianshipClaim?

  @@unique([guardianId, studentId])
  @@index([tenantId])
  @@index([studentId, status])
  @@map("guardianship")
}

// ---------------------------------------------------------------------------
// E9-S1 — Enrollment self-service: the parent child-claim (GuardianshipClaim)
// ---------------------------------------------------------------------------

/// E9 — a parent's self-service request to be attached to a child. The provenance
/// + lifecycle record that DRIVES a Guardianship (the request→link pattern, the
/// E1-S3 MeetingRequest precedent). The claim is the request; the Guardianship is
/// the access grant. A claim is created on EVERY parent submit (matched or not);
/// only a matched claim also drives a `pending` Guardianship. A `match_failed`
/// claim has matchedStudentId=null + guardianshipId=null — no Guardianship orphan.
/// Carries tenantId+schoolId (the ADR-002 application-level scoping family).
/// See docs/adr/ADR-022-enrollment-self-service-child-claim.md.
model GuardianshipClaim {
  id                 String                  @id @default(uuid()) @db.Uuid
  tenantId           String                  @map("tenant_id") @db.Uuid
  schoolId           String                  @map("school_id") @db.Uuid
  guardianId         String                  @map("guardian_id") @db.Uuid
  // What the parent typed (the audit/non-leak evidence; never echoed on a no-match):
  claimedFirstName   String                  @map("claimed_first_name")
  claimedLastName    String                  @map("claimed_last_name")
  claimedDob         DateTime?               @map("claimed_dob") @db.Date
  claimedExternalRef String?                 @map("claimed_external_ref")
  relationship       GuardianRelationship
  // The matcher decision + the driven link (null on a no-match):
  matchedStudentId   String?                 @map("matched_student_id") @db.Uuid
  guardianshipId     String?                 @unique @map("guardianship_id") @db.Uuid
  status             GuardianshipClaimStatus @default(submitted)
  decisionReason     String?                 @map("decision_reason")
  decidedBy          String?                 @map("decided_by") @db.Uuid
  decidedAt          DateTime?               @map("decided_at") @db.Timestamptz(6)
  createdAt          DateTime                @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt          DateTime                @updatedAt @map("updated_at") @db.Timestamptz(6)

  guardian     Guardian      @relation(fields: [guardianId], references: [id], onDelete: Cascade)
  student      Student?      @relation("ClaimMatchedStudent", fields: [matchedStudentId], references: [id], onDelete: SetNull)
  guardianship Guardianship? @relation(fields: [guardianshipId], references: [id], onDelete: SetNull)

  // Idempotency: at most ONE open (submitted) claim per (guardian, matched child).
  // A partial unique on (guardianId, matchedStudentId) WHERE status='submitted'
  // is applied as a raw partial index (the ADR-020/E7-S2 BookingIndexBootstrap
  // idiom) since Prisma cannot express a partial @@unique. See
  // guardianship-claim-index.bootstrap.ts.
  @@index([tenantId, status])
  @@index([guardianId, status])
  @@map("guardianship_claim")
}

// ── E9 — additive enum (net-new type; no existing enum touched) ──
enum GuardianshipClaimStatus {
  submitted // pending admin review (the queue). Drives a `pending` Guardianship on a match.
  approved // admin approved → the driven Guardianship is now `active` (access granted).
  rejected // admin rejected (decisionReason set). The parent may re-submit corrected details.
  match_failed // deny-by-default no/ambiguous match — NO Guardianship driven, never leaked.
  withdrawn // the parent cancelled a still-`submitted` claim.
}

/// Student enrollment in a class section for a given academic year.
model Enrollment {
  id             String           @id @default(uuid()) @db.Uuid
  tenantId       String           @map("tenant_id") @db.Uuid
  studentId      String           @map("student_id") @db.Uuid
  classSectionId String           @map("class_section_id") @db.Uuid
  academicYearId String           @map("academic_year_id") @db.Uuid
  status         EnrollmentStatus @default(active)
  enrolledAt     DateTime         @default(now()) @map("enrolled_at") @db.Timestamptz(6)
  endedAt        DateTime?        @map("ended_at") @db.Timestamptz(6)
  endReason      String?          @map("end_reason")
  createdAt      DateTime         @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime         @updatedAt @map("updated_at") @db.Timestamptz(6)

  student      Student      @relation(fields: [studentId], references: [id], onDelete: Cascade)
  classSection ClassSection @relation(fields: [classSectionId], references: [id], onDelete: Restrict)
  academicYear AcademicYear @relation(fields: [academicYearId], references: [id], onDelete: Restrict)

  // A student can have at most one active enrollment per academic year. We enforce uniqueness on
  // (studentId, academicYearId) when status='active' via a partial unique index in migration SQL.
  @@unique([studentId, classSectionId, academicYearId])
  @@index([tenantId])
  @@index([classSectionId, status])
  @@index([academicYearId, status])
  @@map("enrollment")
}

// ---------------------------------------------------------------------------
// School calendar (Phase 2C) — vacations, holidays, exam periods, events
// ---------------------------------------------------------------------------

/// One calendar event. Can be a vacation block, public holiday, exam window, meeting, etc.
/// Scope determines who's concerned: whole school, a cycle, a grade level, or a specific class.
model CalendarEvent {
  id             String                  @id @default(uuid()) @db.Uuid
  tenantId       String                  @map("tenant_id") @db.Uuid
  schoolId       String                  @map("school_id") @db.Uuid
  academicYearId String?                 @map("academic_year_id") @db.Uuid
  type           CalendarEventType
  scope          CalendarEventScope      @default(school_wide)
  visibility     CalendarEventVisibility @default(all)
  title          String
  description    String?
  startsAt       DateTime                @map("starts_at") @db.Timestamptz(6)
  endsAt         DateTime                @map("ends_at") @db.Timestamptz(6)
  allDay         Boolean                 @default(true) @map("all_day")
  color          String?
  icon           String?
  // For scoped events: which cycle/level/class is concerned (null for school_wide).
  cycleId        String?                 @map("cycle_id") @db.Uuid
  gradeLevelId   String?                 @map("grade_level_id") @db.Uuid
  classSectionId String?                 @map("class_section_id") @db.Uuid
  createdBy      String?                 @map("created_by") @db.Uuid
  createdAt      DateTime                @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime                @updatedAt @map("updated_at") @db.Timestamptz(6)

  school       School        @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  academicYear AcademicYear? @relation(fields: [academicYearId], references: [id], onDelete: SetNull)
  cycle        Cycle?        @relation(fields: [cycleId], references: [id], onDelete: Cascade)
  gradeLevel   GradeLevel?   @relation(fields: [gradeLevelId], references: [id], onDelete: Cascade)
  classSection ClassSection? @relation(fields: [classSectionId], references: [id], onDelete: Cascade)

  @@index([tenantId, schoolId, startsAt])
  @@index([schoolId, type])
  @@index([academicYearId])
  @@map("calendar_event")
}

// ---------------------------------------------------------------------------
// Bulk imports (Phase 2B) — generic pipeline for any entity type
// ---------------------------------------------------------------------------

/// One bulk-import operation. Holds the raw CSV (Phase 2B keeps it inline; Phase 2C
/// moves it to MinIO for big files). All rows live in ImportRow.
model ImportBatch {
  id           String       @id @default(uuid()) @db.Uuid
  tenantId     String       @map("tenant_id") @db.Uuid
  schoolId     String       @map("school_id") @db.Uuid
  type         ImportType
  fileName     String       @map("file_name")
  rawCsv       String?      @map("raw_csv") @db.Text
  status       ImportStatus @default(uploaded)
  mode         ImportMode?
  summary      Json         @default("{}")
  triggeredBy  String?      @map("triggered_by") @db.Uuid
  startedAt    DateTime     @default(now()) @map("started_at") @db.Timestamptz(6)
  validatedAt  DateTime?    @map("validated_at") @db.Timestamptz(6)
  appliedAt    DateTime?    @map("applied_at") @db.Timestamptz(6)
  rolledBackAt DateTime?    @map("rolled_back_at") @db.Timestamptz(6)
  errorMessage String?      @map("error_message")
  // E11-S3 — provenance (additive, nullable + defaulted ⇒ existing rows read
  // `csv_upload`). `rosterSourceId` is set only when origin = oneroster.
  origin         ImportOrigin? @default(csv_upload) @map("origin")
  rosterSourceId String?       @map("roster_source_id") @db.Uuid
  createdAt    DateTime     @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime     @updatedAt @map("updated_at") @db.Timestamptz(6)

  school       School        @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  rosterSource RosterSource? @relation(fields: [rosterSourceId], references: [id], onDelete: SetNull)
  rows         ImportRow[]

  @@index([tenantId, schoolId, createdAt])
  @@index([rosterSourceId])
  @@map("import_batch")
}

/// One row of a bulk import. Tracks validation outcome, applied entity, and rollback.
model ImportRow {
  id                String          @id @default(uuid()) @db.Uuid
  batchId           String          @map("batch_id") @db.Uuid
  rowIndex          Int             @map("row_index")
  status            ImportRowStatus @default(pending)
  payload           Json
  errors            Json?
  createdEntityId   String?         @map("created_entity_id") @db.Uuid
  createdEntityType String?         @map("created_entity_type")
  // E11-S2 — reconciliation classification (additive, nullable ⇒ existing rows
  // read null and the health panel degrades to neutral zeros, never a crash).
  // conflictFields holds [{ field, current, source }] for a `conflict` row only —
  // an allow-list of identity fields (never notes/free-text/medical), capped per
  // row, inheriting the batch tenant check (no row endpoint bypasses it).
  reconciliation    ReconciliationClass? @map("reconciliation")
  conflictFields    Json?                @map("conflict_fields")
  createdAt         DateTime        @default(now()) @map("created_at") @db.Timestamptz(6)

  batch ImportBatch @relation(fields: [batchId], references: [id], onDelete: Cascade)

  @@unique([batchId, rowIndex])
  @@index([batchId, status])
  @@index([batchId, reconciliation])
  @@map("import_row")
}

/// E11-S3 — a connected OneRoster (or other standards) roster source. Config +
/// provenance only: a sync PRODUCES an ImportBatch (origin = oneroster), so the
/// whole validate→apply→reconcile→rollback machinery is reused (no parallel
/// pipeline). Tenant + school scoped, admin-only (`integrations.write`).
///
/// SECRET HANDLING (Sentinel gate): the raw credential is NEVER stored in
/// plaintext and NEVER returned to the client. `credentialRef` holds an opaque
/// server-side ref only, resolved at pull time. For the CSV-bundle v1 the
/// credential is unused (the bundle is uploaded in the sync request itself).
model RosterSource {
  id            String           @id @default(uuid()) @db.Uuid
  tenantId      String           @map("tenant_id") @db.Uuid
  schoolId      String           @map("school_id") @db.Uuid
  kind          RosterSourceKind
  label         String
  baseUrl       String?          @map("base_url")
  credentialRef String?          @map("credential_ref")
  status        RosterSyncStatus @default(idle)
  lastSyncAt    DateTime?        @map("last_sync_at") @db.Timestamptz(6)
  lastBatchId   String?          @map("last_batch_id") @db.Uuid
  lastError     String?          @map("last_error")
  createdBy     String?          @map("created_by") @db.Uuid
  createdAt     DateTime         @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt     DateTime         @updatedAt @map("updated_at") @db.Timestamptz(6)

  school   School        @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  batches  ImportBatch[]

  @@index([tenantId, schoolId])
  @@map("roster_source")
}

model Branding {
  schoolId     String  @id @map("school_id") @db.Uuid
  logoUrl      String? @map("logo_url")
  faviconUrl   String? @map("favicon_url")
  displayName  String  @map("display_name")
  primaryColor String  @default("oklch(0.62 0.18 250)") @map("primary_color")
  accentColor  String? @map("accent_color")
  fontFamily   String? @map("font_family")
  emailFrom    String? @map("email_from")
  emailReplyTo String? @map("email_reply_to")

  school School @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  @@map("branding")
}

// ---------------------------------------------------------------------------
// Identity
// ---------------------------------------------------------------------------
model UserProfile {
  id              String     @id @default(uuid()) @db.Uuid
  tenantId        String     @map("tenant_id") @db.Uuid
  authProviderId  String?    @unique @map("auth_provider_id")
  firstName       String     @map("first_name")
  lastName        String     @map("last_name")
  email           String     @db.Citext
  phone           String?
  emailVerifiedAt DateTime?  @map("email_verified_at") @db.Timestamptz(6)
  phoneVerifiedAt DateTime?  @map("phone_verified_at") @db.Timestamptz(6)
  photoUrl        String?    @map("photo_url")
  status          UserStatus @default(active)
  locale          String     @default("fr-FR")
  preferences     Json       @default("{}")
  createdAt       DateTime   @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime   @updatedAt @map("updated_at") @db.Timestamptz(6)

  tenant                  Tenant                   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  userRoles               UserRole[]
  guardian                Guardian?
  teacherProfile          TeacherProfile?
  exportJobs              ExportJob[]
  notifications           Notification[]
  notificationPreferences NotificationPreference[]
  meetingRequestsMade     MeetingRequest[]         @relation("MeetingRequestRequester")
  meetingRequestsAssigned MeetingRequest[]         @relation("MeetingRequestAssignee")
  // E2-S1 — parent ↔ teacher messaging. A UserProfile participates as the parent
  // OR the teacher of a thread; the participant rows carry per-side read state;
  // sent messages are attributed back here. (E2-S4 adds the report-reporter
  // back-relation for safety moderation.)
  conversationsAsParent     Conversation[]            @relation("ConversationParent")
  conversationsAsTeacher    Conversation[]            @relation("ConversationTeacher")
  conversationParticipants  ConversationParticipant[]
  conversationMessages      ConversationMessage[]     @relation("ConversationMessageSender")
  conversationReports       ConversationReport[]      @relation("ConversationReportReporter")
  // E7 — a UserProfile can BE a (teacher) tutor, CREATE remediation plans, and
  // BOOK tutor slots (additive back-relations; disambiguated like the messaging ones).
  tutorAccounts             Tutor[]                   @relation("TutorUser")
  remediationPlansCreated   RemediationPlan[]         @relation("RemediationPlanCreator")
  bookingsMade              Booking[]                 @relation("BookingBooker")
  // E8-S1 — the linked pupil dossier (1:1, additive). A `student`-role login
  // resolves its one Student via this back-relation. Most UserProfiles have none.
  studentAccount            Student?                  @relation("StudentAccount")

  @@unique([tenantId, email])
  @@index([tenantId])
  @@map("user_profile")
}

// ---------------------------------------------------------------------------
// RBAC: Permissions / Roles
// ---------------------------------------------------------------------------
model Permission {
  id           String  @id @default(uuid()) @db.Uuid
  code         String  @unique
  label        String
  resourceType String  @map("resource_type")
  action       String
  description  String?

  rolePermissions RolePermission[]

  @@map("permission")
}

model Role {
  id          String  @id @default(uuid()) @db.Uuid
  schoolId    String? @map("school_id") @db.Uuid
  name        String
  slug        String
  description String?
  isSystem    Boolean @default(false) @map("is_system")
  portal      Portal?

  rolePermissions RolePermission[]
  userRoles       UserRole[]

  @@unique([schoolId, slug])
  @@map("role")
}

model RolePermission {
  roleId       String @map("role_id") @db.Uuid
  permissionId String @map("permission_id") @db.Uuid

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
  @@map("role_permission")
}

model UserRole {
  id            String    @id @default(uuid()) @db.Uuid
  userProfileId String    @map("user_profile_id") @db.Uuid
  roleId        String    @map("role_id") @db.Uuid
  schoolId      String?   @map("school_id") @db.Uuid
  grantedBy     String?   @map("granted_by") @db.Uuid
  grantedAt     DateTime  @default(now()) @map("granted_at") @db.Timestamptz(6)
  revokedAt     DateTime? @map("revoked_at") @db.Timestamptz(6)

  userProfile UserProfile @relation(fields: [userProfileId], references: [id], onDelete: Cascade)
  role        Role        @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([userProfileId, roleId, schoolId])
  @@map("user_role")
}

// ===========================================================================
// Phase 4 — Teaching & assessment
// ===========================================================================

/// School-specific metadata for a teacher. A teacher is fundamentally a UserProfile
/// with the realm role 'teacher'; this model carries the *educational* metadata
/// (specialty, hire date, internal ref) and is the FK target for assignments.
model TeacherProfile {
  id            String    @id @default(uuid()) @db.Uuid
  tenantId      String    @map("tenant_id") @db.Uuid
  schoolId      String    @map("school_id") @db.Uuid
  userProfileId String    @unique @map("user_profile_id") @db.Uuid
  externalRef   String?   @map("external_ref")
  specialty     String?
  active        Boolean   @default(true)
  hiredAt       DateTime? @map("hired_at") @db.Date
  notes         String?
  createdAt     DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt     DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)

  userProfile         UserProfile          @relation(fields: [userProfileId], references: [id], onDelete: Cascade)
  school              School               @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  teachingAssignments TeachingAssignment[]
  assessments         Assessment[]
  lessons             LessonEntry[]
  classSessions       ClassSession[]
  // E7 — a teacher can be linked to one or more tutor catalogue rows (additive).
  tutorRoles          Tutor[]

  @@unique([schoolId, externalRef])
  @@index([tenantId, schoolId])
  @@map("teacher_profile")
}

/// Edge of the (Teacher × Class × Subject) triangle. One teacher can teach the
/// same subject across multiple classes; one class can have multiple teachers
/// for different subjects; one subject can have several teachers in the same class
/// (rare, but supported — e.g. co-teaching). `isMainTeacher` flags the
/// "professeur principal" of the class (one per class section).
/// `role` distingue les deux modèles d'affectation (principal / assistant pour
/// le primaire-maternelle, subject_teacher pour le collège-lycée). Il reste
/// synchronisé avec `isMainTeacher` : role=principal ⇔ isMainTeacher=true.
model TeachingAssignment {
  id               String         @id @default(uuid()) @db.Uuid
  tenantId         String         @map("tenant_id") @db.Uuid
  teacherProfileId String         @map("teacher_profile_id") @db.Uuid
  classSectionId   String         @map("class_section_id") @db.Uuid
  subjectId        String         @map("subject_id") @db.Uuid
  academicYearId   String         @map("academic_year_id") @db.Uuid
  weeklyHours      Decimal?       @map("weekly_hours") @db.Decimal(4, 2)
  isMainTeacher    Boolean        @default(false) @map("is_main_teacher")
  role             AssignmentRole @default(subject_teacher)
  createdAt        DateTime       @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt        DateTime       @updatedAt @map("updated_at") @db.Timestamptz(6)

  teacherProfile TeacherProfile @relation(fields: [teacherProfileId], references: [id], onDelete: Cascade)
  classSection   ClassSection   @relation(fields: [classSectionId], references: [id], onDelete: Cascade)
  subject        Subject        @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  academicYear   AcademicYear   @relation(fields: [academicYearId], references: [id], onDelete: Cascade)
  assessments    Assessment[]
  lessons        LessonEntry[]
  classSessions  ClassSession[]

  @@unique([teacherProfileId, classSectionId, subjectId])
  @@index([tenantId, classSectionId])
  @@index([academicYearId])
  @@index([subjectId])
  @@map("teaching_assignment")
}

/// An assessment (DST, DM, oral interrogation…) owned by a (teacher × class ×
/// subject) tuple. Multi-grade: one assessment → one Grade per student of the class.
/// Coefficient defaults to the subject-level coefficient (resolved against the
/// class's GradeLevel) unless explicitly overridden here.
model Assessment {
  id                   String         @id @default(uuid()) @db.Uuid
  tenantId             String         @map("tenant_id") @db.Uuid
  teachingAssignmentId String         @map("teaching_assignment_id") @db.Uuid
  teacherProfileId     String         @map("teacher_profile_id") @db.Uuid
  termId               String?        @map("term_id") @db.Uuid
  title                String
  description          String?
  kind                 AssessmentKind @default(written_test)
  scheduledAt          DateTime?      @map("scheduled_at") @db.Timestamptz(6)
  conductedAt          DateTime?      @map("conducted_at") @db.Timestamptz(6)
  maxScore             Decimal        @default(20.0) @map("max_score") @db.Decimal(5, 2)
  coefficientOverride  Decimal?       @map("coefficient_override") @db.Decimal(4, 2)
  isPublished          Boolean        @default(false) @map("is_published")
  publishedAt          DateTime?      @map("published_at") @db.Timestamptz(6)
  createdAt            DateTime       @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt            DateTime       @updatedAt @map("updated_at") @db.Timestamptz(6)

  teachingAssignment TeachingAssignment @relation(fields: [teachingAssignmentId], references: [id], onDelete: Cascade)
  teacherProfile     TeacherProfile     @relation(fields: [teacherProfileId], references: [id], onDelete: Cascade)
  term               Term?              @relation(fields: [termId], references: [id], onDelete: SetNull)
  grades             Grade[]

  @@index([tenantId])
  @@index([teachingAssignmentId, scheduledAt])
  @@index([termId])
  @@map("assessment")
}

/// One grade per (assessment × student). `value` is null when `isAbsent`.
/// Status workflow: draft → published → revised (each revision saved to
/// GradeRevision for audit).
model Grade {
  id           String      @id @default(uuid()) @db.Uuid
  tenantId     String      @map("tenant_id") @db.Uuid
  assessmentId String      @map("assessment_id") @db.Uuid
  studentId    String      @map("student_id") @db.Uuid
  value        Decimal?    @db.Decimal(5, 2)
  isAbsent     Boolean     @default(false) @map("is_absent")
  comment      String?
  status       GradeStatus @default(draft)
  enteredBy    String      @map("entered_by") @db.Uuid
  enteredAt    DateTime    @default(now()) @map("entered_at") @db.Timestamptz(6)
  publishedAt  DateTime?   @map("published_at") @db.Timestamptz(6)
  // E3-S1 — teacher grade-flag (TEACHER_COMMENT_FLAG rule). Additive, defaulted/
  // nullable, no backfill. `flaggedBy` is lightweight provenance (a UserProfile
  // id, plain @db.Uuid like `enteredBy` — NOT an FK relation). `flagNote` is a
  // short, bounded teacher reason (capped at the DTO), never a messaging surface.
  isFlagged    Boolean     @default(false) @map("is_flagged")
  flaggedAt    DateTime?   @map("flagged_at") @db.Timestamptz(6)
  flaggedBy    String?     @map("flagged_by") @db.Uuid
  flagNote     String?     @map("flag_note")
  createdAt    DateTime    @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime    @updatedAt @map("updated_at") @db.Timestamptz(6)

  assessment Assessment      @relation(fields: [assessmentId], references: [id], onDelete: Cascade)
  student    Student         @relation(fields: [studentId], references: [id], onDelete: Cascade)
  revisions  GradeRevision[]

  @@unique([assessmentId, studentId])
  @@index([tenantId])
  @@index([studentId, status])
  @@index([tenantId, isFlagged])
  @@map("grade")
}

/// Append-only audit log of grade modifications after publication.
model GradeRevision {
  id            String   @id @default(uuid()) @db.Uuid
  gradeId       String   @map("grade_id") @db.Uuid
  previousValue Decimal? @map("previous_value") @db.Decimal(5, 2)
  newValue      Decimal? @map("new_value") @db.Decimal(5, 2)
  reason        String
  revisedBy     String   @map("revised_by") @db.Uuid
  revisedAt     DateTime @default(now()) @map("revised_at") @db.Timestamptz(6)

  grade Grade @relation(fields: [gradeId], references: [id], onDelete: Cascade)

  @@index([gradeId, revisedAt])
  @@map("grade_revision")
}

// ===========================================================================
// Phase 5 — Class sessions, cahier de texte, attendance, announcements
// ===========================================================================

/// A single class-time slot (a "session"). A session is the *unit* under which
/// attendance is taken and a lesson entry is written.
model ClassSession {
  id                   String   @id @default(uuid()) @db.Uuid
  tenantId             String   @map("tenant_id") @db.Uuid
  teachingAssignmentId String   @map("teaching_assignment_id") @db.Uuid
  teacherProfileId     String   @map("teacher_profile_id") @db.Uuid
  date                 DateTime @db.Date
  startTime            String?  @map("start_time")
  endTime              String?  @map("end_time")
  topic                String?
  cancelled            Boolean  @default(false)
  createdAt            DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt            DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  teachingAssignment TeachingAssignment @relation(fields: [teachingAssignmentId], references: [id], onDelete: Cascade)
  teacherProfile     TeacherProfile     @relation(fields: [teacherProfileId], references: [id], onDelete: Cascade)
  attendanceRecords  AttendanceRecord[]
  lessonEntry        LessonEntry?

  @@index([tenantId])
  @@index([teachingAssignmentId, date])
  @@map("class_session")
}

/// "Cahier de texte" entry — what was taught + homework given. Linked to a
/// session when applicable, but can also exist standalone (for catch-up).
model LessonEntry {
  id                   String       @id @default(uuid()) @db.Uuid
  tenantId             String       @map("tenant_id") @db.Uuid
  teachingAssignmentId String       @map("teaching_assignment_id") @db.Uuid
  teacherProfileId     String       @map("teacher_profile_id") @db.Uuid
  classSessionId       String?      @unique @map("class_session_id") @db.Uuid
  date                 DateTime     @db.Date
  title                String
  content              String       @db.Text
  homework             String?      @db.Text
  homeworkDueAt        DateTime?    @map("homework_due_at") @db.Date
  status               LessonStatus @default(published)
  attachments          Json         @default("[]")
  createdAt            DateTime     @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt            DateTime     @updatedAt @map("updated_at") @db.Timestamptz(6)

  teachingAssignment TeachingAssignment @relation(fields: [teachingAssignmentId], references: [id], onDelete: Cascade)
  teacherProfile     TeacherProfile     @relation(fields: [teacherProfileId], references: [id], onDelete: Cascade)
  classSession       ClassSession?      @relation(fields: [classSessionId], references: [id], onDelete: SetNull)

  @@index([tenantId])
  @@index([teachingAssignmentId, date])
  @@map("lesson_entry")
}

model AttendanceRecord {
  id             String           @id @default(uuid()) @db.Uuid
  tenantId       String           @map("tenant_id") @db.Uuid
  classSessionId String           @map("class_session_id") @db.Uuid
  studentId      String           @map("student_id") @db.Uuid
  status         AttendanceStatus
  arrivedAt      String?          @map("arrived_at")
  comment        String?
  recordedBy     String           @map("recorded_by") @db.Uuid
  recordedAt     DateTime         @default(now()) @map("recorded_at") @db.Timestamptz(6)
  justifiedAt    DateTime?        @map("justified_at") @db.Timestamptz(6)
  justifiedBy    String?          @map("justified_by") @db.Uuid
  justification  String?

  classSession ClassSession @relation(fields: [classSessionId], references: [id], onDelete: Cascade)
  student      Student      @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([classSessionId, studentId])
  @@index([tenantId])
  @@index([studentId, recordedAt])
  @@map("attendance_record")
}

/// A communication broadcast by school staff. Scope determines targeting:
/// school-wide, cycle, level, class, individual student (= her guardians), or
/// individual user. Recipients are computed at publish time and stored in
/// AnnouncementReceipt for read-tracking.
model Announcement {
  id             String               @id @default(uuid()) @db.Uuid
  tenantId       String               @map("tenant_id") @db.Uuid
  schoolId       String               @map("school_id") @db.Uuid
  title          String
  body           String               @db.Text
  scope          AnnouncementScope
  priority       AnnouncementPriority @default(normal)
  cycleId        String?              @map("cycle_id") @db.Uuid
  gradeLevelId   String?              @map("grade_level_id") @db.Uuid
  classSectionId String?              @map("class_section_id") @db.Uuid
  studentId      String?              @map("student_id") @db.Uuid
  userProfileId  String?              @map("user_profile_id") @db.Uuid
  publishedAt    DateTime?            @map("published_at") @db.Timestamptz(6)
  expiresAt      DateTime?            @map("expires_at") @db.Timestamptz(6)
  pinned         Boolean              @default(false)
  authorId       String               @map("author_id") @db.Uuid
  authorRoleHint String?              @map("author_role_hint")
  attachments    Json                 @default("[]")
  createdAt      DateTime             @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime             @updatedAt @map("updated_at") @db.Timestamptz(6)

  school       School                @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  cycle        Cycle?                @relation(fields: [cycleId], references: [id], onDelete: SetNull)
  gradeLevel   GradeLevel?           @relation(fields: [gradeLevelId], references: [id], onDelete: SetNull)
  classSection ClassSection?         @relation(fields: [classSectionId], references: [id], onDelete: SetNull)
  student      Student?              @relation(fields: [studentId], references: [id], onDelete: SetNull)
  recipients   AnnouncementReceipt[]

  @@index([tenantId, schoolId, publishedAt])
  @@index([scope])
  @@map("announcement")
}

model AnnouncementReceipt {
  id             String    @id @default(uuid()) @db.Uuid
  announcementId String    @map("announcement_id") @db.Uuid
  userProfileId  String    @map("user_profile_id") @db.Uuid
  readAt         DateTime? @map("read_at") @db.Timestamptz(6)
  createdAt      DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)

  announcement Announcement @relation(fields: [announcementId], references: [id], onDelete: Cascade)

  @@unique([announcementId, userProfileId])
  @@index([userProfileId, readAt])
  @@map("announcement_receipt")
}

// ---------------------------------------------------------------------------
// Audit append-only (RLS + REVOKE configurés en migration SQL)
// ---------------------------------------------------------------------------
model AuditLog {
  id           String   @id @default(uuid()) @db.Uuid
  tenantId     String   @map("tenant_id") @db.Uuid
  actorId      String?  @map("actor_id") @db.Uuid
  actorRole    String?  @map("actor_role")
  portal       String?
  action       String
  resourceType String   @map("resource_type")
  resourceId   String?  @map("resource_id") @db.Uuid
  before       Json?
  after        Json?
  ipAddress    String?  @map("ip_address") @db.Inet
  userAgent    String?  @map("user_agent")
  hash         String?
  prevHash     String?  @map("prev_hash")
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  @@index([tenantId, createdAt])
  @@map("audit_log")
}

// ---------------------------------------------------------------------------
// Document exports (XLSX/PDF) — minimal model for the admin dashboard.
// The async worker (BullMQ) that *generates* these files is planned for R7;
// this table is the persistence layer so the "Exports récents" panel can
// surface real rows. `status='succeeded'` is the only state used by R7
// stub seed data — the worker will populate other states later.
// ---------------------------------------------------------------------------
enum ExportKind {
  grades_xlsx
  report_card_pdf
  enrollment_xlsx
  attendance_xlsx
  audit_csv
}

enum ExportStatus {
  pending
  running
  succeeded
  failed
}

model ExportJob {
  id              String        @id @default(uuid()) @db.Uuid
  tenantId        String        @map("tenant_id") @db.Uuid
  schoolId        String?       @map("school_id") @db.Uuid
  requestedBy     String        @map("requested_by") @db.Uuid
  kind            ExportKind
  parameters      Json          @default("{}")
  status          ExportStatus  @default(pending)
  fileName        String        @map("file_name")
  fileUrl         String?       @map("file_url")
  fileSizeBytes   Int?          @map("file_size_bytes")
  errorMessage    String?       @map("error_message")
  startedAt       DateTime?     @map("started_at") @db.Timestamptz(6)
  finishedAt      DateTime?     @map("finished_at") @db.Timestamptz(6)
  createdAt       DateTime      @default(now()) @map("created_at") @db.Timestamptz(6)

  requester UserProfile @relation(fields: [requestedBy], references: [id], onDelete: Restrict)

  @@index([tenantId, status, createdAt])
  @@index([tenantId, schoolId, createdAt])
  @@map("export_job")
}

// ---------------------------------------------------------------------------
// Outbox event pattern
// ---------------------------------------------------------------------------
enum OutboxStatus {
  pending
  sent
  failed
}

model OutboxEvent {
  id            String       @id @default(uuid()) @db.Uuid
  aggregateType String       @map("aggregate_type")
  aggregateId   String       @map("aggregate_id") @db.Uuid
  type          String
  payload       Json
  status        OutboxStatus @default(pending)
  createdAt     DateTime     @default(now()) @map("created_at") @db.Timestamptz(6)
  sentAt        DateTime?    @map("sent_at") @db.Timestamptz(6)
  attempts      Int          @default(0)
  lastError     String?      @map("last_error")

  @@index([status, createdAt])
  @@map("outbox_event")
}

// ---------------------------------------------------------------------------
// Alert engine (R6) — rule config + materialised instances
// ---------------------------------------------------------------------------

enum AlertRuleCode {
  LOW_SUBJECT_AVG
  NEGATIVE_TREND
  REPEATED_FAILURE
  MISSING_ASSESSMENT
  HIGH_ABSENCE
  TEACHER_COMMENT_FLAG
  BEHAVIOR_ALERT
  IMPROVEMENT
}

enum AlertSeverity {
  low
  medium
  high
}

enum AlertStatus {
  open
  acknowledged
  resolved
  dismissed
}

/// One row per (tenant, code). Disabled by default at install — admins
/// activate what's relevant. `parameters` stores rule-specific thresholds
/// (e.g. { "threshold": 10 } for LOW_SUBJECT_AVG).
model AlertRule {
  id          String        @id @default(uuid()) @db.Uuid
  tenantId    String        @map("tenant_id") @db.Uuid
  schoolId    String?       @map("school_id") @db.Uuid
  code        AlertRuleCode
  enabled     Boolean       @default(false)
  severity    AlertSeverity @default(medium)
  parameters  Json          @default("{}")
  createdAt   DateTime      @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime      @updatedAt @map("updated_at") @db.Timestamptz(6)

  instances AlertInstance[]

  @@unique([tenantId, schoolId, code])
  @@index([tenantId, enabled])
  @@map("alert_rule")
}

// ---------------------------------------------------------------------------
// Notifications (R8) — unified in-app notification stream
// ---------------------------------------------------------------------------

enum NotificationKind {
  announcement
  alert
  grade_published
  enrollment_status
  lesson_published
  system
  // E1-S4 — opt-in weekly parent digest channel (email-only concept). Additive
  // enum value; no new table. The worker reads NotificationPreference rows with
  // kind=weekly_digest & emailEnabled=true to resolve digest recipients, and
  // writes a Notification(kind=weekly_digest, readAt set) as the weekly sent-marker.
  weekly_digest
  // E2-S1 — parent ↔ teacher messaging. Additive enum value; no new table. A new
  // ConversationMessage notifies the OTHER participant in-app via
  // NotificationsService.createMany(kind=message, sourceType=conversation).
  message
  // E7-S1 — remediation & tutoring loop. Additive enum value; no new table. A
  // booking created/confirmed (S2) notifies the tutor + parent in-app via
  // NotificationsService.createMany(kind=remediation, sourceType=booking). The
  // enum value lands in S1 so the dispatcher seam exists before the booking write.
  remediation
}

enum NotificationSeverity {
  info
  success
  warning
  danger
}

/// E5-S2 — per-(user, kind) notification CADENCE. The PRIMARY delivery control;
/// it composes with the channel booleans (spec FR-2 / data-model §1.2 truth table):
///  - instant       → today's behaviour: deliver per-event (in-app iff inAppEnabled,
///                    email iff emailEnabled). The default — every existing row
///                    resolves here, so the field is a zero-behaviour-change addition.
///  - daily_digest  → suppress the per-event EMAIL; the in-app row is still written
///                    iff inAppEnabled (bell stays a live feed), and the event is
///                    bundled into one grouped email/day by the notifications-digest
///                    cron iff emailEnabled. (Edge: in-app off + email on writes a
///                    hidden readAt=now source row so the cron has a durable source.)
///  - off           → the STRONGEST value — "off wins": no in-app row, no per-event
///                    email, never in the digest, for that kind. The channel booleans
///                    are preserved so the user can un-mute by switching cadence back.
enum NotificationCadence {
  instant
  daily_digest
  off
}

/// Per-user opt-in/out per notification kind, per channel. Default (missing
/// row) is "in-app on, email off, push off". Rows are written only when the
/// user diverges from defaults.
model NotificationPreference {
  id            String           @id @default(uuid()) @db.Uuid
  tenantId      String           @map("tenant_id") @db.Uuid
  userProfileId String           @map("user_profile_id") @db.Uuid
  kind          NotificationKind
  inAppEnabled  Boolean          @default(true) @map("in_app_enabled")
  emailEnabled  Boolean          @default(false) @map("email_enabled")
  pushEnabled   Boolean          @default(false) @map("push_enabled")
  // --- E5-S2: per-kind email cadence (additive, defaulted ⇒ zero behaviour change) ---
  cadence       NotificationCadence @default(instant) @map("cadence")
  updatedAt     DateTime         @updatedAt @map("updated_at") @db.Timestamptz(6)

  userProfile UserProfile @relation(fields: [userProfileId], references: [id], onDelete: Cascade)

  @@unique([userProfileId, kind])
  @@index([tenantId])
  // E5-S2: lets the daily-digest cron resolve "who wants a grouped email of kind K"
  // cheaply, tenant-first, without scanning every preference row.
  @@index([tenantId, cadence, emailEnabled])
  @@map("notification_preference")
}

/// One row per recipient × event. The dispatcher fans out a source event to
/// every interested user (e.g. one announcement → N notifications, one for
/// each guardian/teacher in scope). Read state is per-recipient.
model Notification {
  id            String               @id @default(uuid()) @db.Uuid
  tenantId      String               @map("tenant_id") @db.Uuid
  userProfileId String               @map("user_profile_id") @db.Uuid
  kind          NotificationKind
  severity      NotificationSeverity @default(info)
  title         String
  body          String?
  /// Optional in-app link (e.g. "/parent/recommendations?studentId=...")
  link          String?
  /// Optional FK identifiers for deep linking + dedup
  sourceType    String?              @map("source_type")
  sourceId      String?              @map("source_id") @db.Uuid
  /// When this notification was first read by the recipient
  readAt        DateTime?            @map("read_at") @db.Timestamptz(6)
  createdAt     DateTime             @default(now()) @map("created_at") @db.Timestamptz(6)

  userProfile UserProfile @relation(fields: [userProfileId], references: [id], onDelete: Cascade)

  @@index([userProfileId, readAt, createdAt])
  @@index([tenantId, kind, createdAt])
  @@map("notification")
}

/// Materialised alert. The evaluator deduplicates by (rule, student,
/// subjectId | null) within a 7-day window so the same condition doesn't
/// spam the parent every 15 minutes.
model AlertInstance {
  id             String         @id @default(uuid()) @db.Uuid
  tenantId       String         @map("tenant_id") @db.Uuid
  schoolId       String?        @map("school_id") @db.Uuid
  ruleId         String         @map("rule_id") @db.Uuid
  code           AlertRuleCode
  severity       AlertSeverity
  status         AlertStatus    @default(open)
  studentId      String         @map("student_id") @db.Uuid
  subjectId      String?        @map("subject_id") @db.Uuid
  classSectionId String?        @map("class_section_id") @db.Uuid
  title          String
  body           String
  /// Optional recommendation surfaced to parents
  recommendation String?
  /// Raw context the rule recorded (kept for audit/debug — not displayed)
  context        Json           @default("{}")
  detectedAt     DateTime       @default(now()) @map("detected_at") @db.Timestamptz(6)
  acknowledgedAt DateTime?      @map("acknowledged_at") @db.Timestamptz(6)
  acknowledgedBy String?        @map("acknowledged_by") @db.Uuid
  resolvedAt     DateTime?      @map("resolved_at") @db.Timestamptz(6)
  resolvedBy     String?        @map("resolved_by") @db.Uuid
  createdAt      DateTime       @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime       @updatedAt @map("updated_at") @db.Timestamptz(6)

  rule         AlertRule    @relation(fields: [ruleId], references: [id], onDelete: Cascade)
  student      Student      @relation(fields: [studentId], references: [id], onDelete: Cascade)
  subject      Subject?     @relation(fields: [subjectId], references: [id], onDelete: SetNull)
  classSection ClassSection? @relation(fields: [classSectionId], references: [id], onDelete: SetNull)
  meetingRequests MeetingRequest[]
  conversations   Conversation[]
  // E7 — remediation plans promoted from this alert (additive back-relation).
  remediationPlans RemediationPlan[]

  @@index([tenantId, status, severity, detectedAt])
  @@index([studentId, status, detectedAt])
  @@map("alert_instance")
}

// ---------------------------------------------------------------------------
// Meeting requests (E1-S3) — parent "talk to the teacher" intent promoted into
// a queryable, tenant-scoped record + teacher/admin action center.
// ---------------------------------------------------------------------------

enum MeetingRequestStatus {
  open
  resolved
  cancelled
}

/// A parent's "I'd like to talk to the teacher about this alert" request,
/// promoted from the E1-S2 append-only `alert.meeting_intent` audit row into a
/// queryable, tenant-scoped record. Created via the guardianship-ABAC path
/// (parent → their child's current teacher/admin); triaged + resolved in the
/// teacher/admin action center. The append-only `AuditLog` row is still written
/// alongside (durable provenance); THIS table is the queryable surface.
model MeetingRequest {
  id           String               @id @default(uuid()) @db.Uuid
  tenantId     String               @map("tenant_id") @db.Uuid
  schoolId     String?              @map("school_id") @db.Uuid
  alertId      String               @map("alert_id") @db.Uuid
  studentId    String               @map("student_id") @db.Uuid
  subjectId    String?              @map("subject_id") @db.Uuid
  alertCode    AlertRuleCode        @map("alert_code")
  /// The parent UserProfile that made the request (audit actorId parity).
  requestedBy  String               @map("requested_by") @db.Uuid
  /// The teacher/admin this request is routed to (see assignment rule).
  /// Nullable: when no main teacher / subject teacher can be resolved it stays
  /// unassigned and is visible to every admin of the school.
  assignedToId String?              @map("assigned_to_id") @db.Uuid
  status       MeetingRequestStatus @default(open)
  /// Optional short free-text note (UNUSED in S3 — reserved so a follow-up can
  /// add a message without a second migration).
  note         String?
  resolvedAt   DateTime?            @map("resolved_at") @db.Timestamptz(6)
  resolvedBy   String?              @map("resolved_by") @db.Uuid
  createdAt    DateTime             @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime             @updatedAt @map("updated_at") @db.Timestamptz(6)

  alert      AlertInstance @relation(fields: [alertId], references: [id], onDelete: Cascade)
  student    Student       @relation(fields: [studentId], references: [id], onDelete: Cascade)
  subject    Subject?      @relation(fields: [subjectId], references: [id], onDelete: SetNull)
  requester  UserProfile   @relation("MeetingRequestRequester", fields: [requestedBy], references: [id], onDelete: Cascade)
  assignedTo UserProfile?  @relation("MeetingRequestAssignee", fields: [assignedToId], references: [id], onDelete: SetNull)

  // Idempotency is now a DB invariant, not an application-level
  // findFirst-then-create. One request per (tenant, alert, requesting parent) —
  // matches the S2 audit-row idempotency key (tenantId, resourceId=alertId,
  // actorId). The create catches P2002 on this constraint for concurrency safety.
  @@unique([tenantId, alertId, requestedBy])
  @@index([tenantId, schoolId, status, createdAt])
  @@index([assignedToId, status, createdAt])
  @@map("meeting_request")
}

// ---------------------------------------------------------------------------
// Conversations (E2-S1) — parent ↔ teacher messaging. Dual-wall ABAC: a thread
// exists only for a (parent, teacher, child) where the parent guards the child
// AND the teacher currently teaches that child. Re-checked at create AND every
// send; a lapsed teaching wall flips the thread to read_only (history preserved).
// E2-S4 adds ConversationReport + ConversationReportStatus (moderation/safety).
// ---------------------------------------------------------------------------

/// Role of a participant within a conversation thread. MVP: exactly one parent +
/// one teacher per thread (admins read via moderation, never as participants).
enum ConversationParticipantRole {
  parent
  teacher
}

/// Lifecycle of a thread. `active` = open for messages; `read_only` = a wall check
/// failed (teacher no longer teaches the child) so history is preserved but no new
/// message is allowed; `archived` = either party archived it; `blocked` = admin
/// moderation froze it (S4). Messages are NEVER deleted — status gates writes only.
enum ConversationStatus {
  active
  read_only
  archived
  blocked
}

/// A thread scoped to exactly one (parent, teacher, child) triple. The
/// `@@unique([tenantId, parentId, teacherId, studentId])` makes "open or reuse
/// the thread" idempotent — clicking the compose CTA twice reuses the same thread
/// (mirrors the MeetingRequest @@unique idempotency from E1-S3).
model Conversation {
  id          String             @id @default(uuid()) @db.Uuid
  tenantId    String             @map("tenant_id") @db.Uuid
  schoolId    String?            @map("school_id") @db.Uuid
  /// The child the thread is about. The guardianship ∩ teaching ABAC is anchored here.
  studentId   String             @map("student_id") @db.Uuid
  /// Denormalised participant ids (also rows in ConversationParticipant) so the
  /// uniqueness/idempotency key and the cheap "my threads" query need no join.
  parentId    String             @map("parent_id") @db.Uuid
  teacherId   String             @map("teacher_id") @db.Uuid
  /// Optional subject context (e.g. the alert's subject) — display only.
  subjectId   String?            @map("subject_id") @db.Uuid
  /// The visionary seed (optional). When a thread is opened from an E1 alert, the
  /// alert id is stored for context. Optional, SetNull on alert delete. NEVER
  /// widens access — the create path re-checks guardianship + that the alert
  /// concerns `studentId`. (Full alertContext exposure on the DTO is S2.)
  alertId     String?            @map("alert_id") @db.Uuid
  status      ConversationStatus @default(active)
  /// Short server-rendered subject line (first message excerpt / alert title) for
  /// the inbox list — avoids a message join on the list query.
  topic       String?
  /// Denormalised for cheap inbox ordering + unread math (set on each new message).
  lastMessageAt   DateTime?      @map("last_message_at") @db.Timestamptz(6)
  lastMessageById String?        @map("last_message_by_id") @db.Uuid
  createdBy   String             @map("created_by") @db.Uuid
  createdAt   DateTime           @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime           @updatedAt @map("updated_at") @db.Timestamptz(6)

  student      Student                   @relation(fields: [studentId], references: [id], onDelete: Cascade)
  parent       UserProfile               @relation("ConversationParent", fields: [parentId], references: [id], onDelete: Cascade)
  teacher      UserProfile               @relation("ConversationTeacher", fields: [teacherId], references: [id], onDelete: Cascade)
  subject      Subject?                  @relation(fields: [subjectId], references: [id], onDelete: SetNull)
  alert        AlertInstance?            @relation(fields: [alertId], references: [id], onDelete: SetNull)
  participants ConversationParticipant[]
  messages     ConversationMessage[]
  reports      ConversationReport[]

  /// Idempotency: one thread per (tenant, parent, teacher, child). Reuse on re-open.
  @@unique([tenantId, parentId, teacherId, studentId])
  /// Inbox queries: "my threads, newest first", tenant- + school-scoped.
  @@index([tenantId, schoolId, status, lastMessageAt])
  @@index([parentId, status, lastMessageAt])
  @@index([teacherId, status, lastMessageAt])
  @@index([studentId])
  @@map("conversation")
}

/// Per-side mutable state of a thread (read receipts, archive, mute). One row per
/// (thread, user). Keeps the model forward-compatible with multi-participant
/// threads without a destructive reshape.
model ConversationParticipant {
  id             String                      @id @default(uuid()) @db.Uuid
  tenantId       String                      @map("tenant_id") @db.Uuid
  conversationId String                      @map("conversation_id") @db.Uuid
  userProfileId  String                      @map("user_profile_id") @db.Uuid
  role           ConversationParticipantRole
  /// Read-receipt anchor: every message with createdAt <= lastReadAt is "read"
  /// by this participant. Unread count = messages newer than this.
  lastReadAt     DateTime?                   @map("last_read_at") @db.Timestamptz(6)
  archivedAt     DateTime?                   @map("archived_at") @db.Timestamptz(6)
  muted          Boolean                     @default(false)
  createdAt      DateTime                    @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime                    @updatedAt @map("updated_at") @db.Timestamptz(6)

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  userProfile  UserProfile  @relation(fields: [userProfileId], references: [id], onDelete: Cascade)

  /// One participant row per (thread, user).
  @@unique([conversationId, userProfileId])
  @@index([tenantId])
  @@index([userProfileId, archivedAt])
  @@map("conversation_participant")
}

/// An immutable (append-only) message. No edit, no soft-delete in the MVP —
/// safety is handled by report (S4) + thread status=blocked, not by deletion.
model ConversationMessage {
  id             String                      @id @default(uuid()) @db.Uuid
  tenantId       String                      @map("tenant_id") @db.Uuid
  conversationId String                      @map("conversation_id") @db.Uuid
  /// Author UserProfile (must be one of the thread's participants — enforced in service).
  senderId       String                      @map("sender_id") @db.Uuid
  senderRole     ConversationParticipantRole @map("sender_role")
  body           String                      @db.Text
  createdAt      DateTime                    @default(now()) @map("created_at") @db.Timestamptz(6)

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender       UserProfile  @relation("ConversationMessageSender", fields: [senderId], references: [id], onDelete: Cascade)

  /// Thread view = messages of a conversation in time order (paged). tenant-first.
  @@index([tenantId, conversationId, createdAt])
  @@index([senderId, createdAt])
  @@map("conversation_message")
}

/// E2-S4 — lifecycle of a safety report. `open` = awaiting admin triage;
/// `reviewed` = an admin looked at it (and optionally froze the thread);
/// `dismissed` = an admin judged it benign. Append-only resolution — never deleted.
enum ConversationReportStatus {
  open
  reviewed
  dismissed
}

/// A safety report raised by a thread participant (E2-S4). Triaged by a
/// school/super admin in the moderation oversight surface. The resolution is
/// stamped (reviewedBy/reviewedAt/status), never deleted — mirroring the
/// platform's append-only ethos. Idempotent: re-reporting an already-`open`
/// thread by the same reporter reuses the open row (the @@unique enforces this),
/// so a parent who clicks "Signaler" twice does not spawn duplicates.
model ConversationReport {
  id             String                   @id @default(uuid()) @db.Uuid
  tenantId       String                   @map("tenant_id") @db.Uuid
  schoolId       String?                  @map("school_id") @db.Uuid
  conversationId String                   @map("conversation_id") @db.Uuid
  reportedBy     String                   @map("reported_by") @db.Uuid
  reason         String                   @db.Text
  status         ConversationReportStatus @default(open)
  reviewedBy     String?                  @map("reviewed_by") @db.Uuid
  reviewedAt     DateTime?                @map("reviewed_at") @db.Timestamptz(6)
  createdAt      DateTime                 @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime                 @updatedAt @map("updated_at") @db.Timestamptz(6)

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  reporter     UserProfile  @relation("ConversationReportReporter", fields: [reportedBy], references: [id], onDelete: Cascade)

  /// One open report per (thread, reporter) — re-report is idempotent while open.
  @@unique([conversationId, reportedBy, status])
  /// Oversight list: open reports per tenant/school, newest first.
  @@index([tenantId, schoolId, status, createdAt])
  @@map("conversation_report")
}

// ============================================================================
// E6 — Analytics Snapshots & pre-computation (snapshot read-models + dirty-queue)
// ----------------------------------------------------------------------------
// Three tenant-scoped, DERIVED, DISPOSABLE cache tables over published/revised
// `Grade` rows (the source of truth stays `Grade`/`Assessment`) plus a durable
// `SnapshotRecomputeTrigger` dirty-queue the worker drains (structural sibling of
// the alerts-cron / notifications-digest poll-drain pattern — NO second BullMQ
// queue, NO Postgres MATERIALIZED VIEW). Every row is fully rebuildable; deleting
// the tables degrades only latency, never correctness. Additive `db push`; no
// existing model changes shape; scope ids are plain @db.Uuid (cache-row
// convention — NO @relation, so no back-relation field is added to any existing
// model). Tenant isolation is enforced by explicit `where: { tenantId }` on every
// read/recompute query, matching the repo-wide de-facto isolation model (the same
// app-level scoping every prior per-tenant table relies on; see ADR-019).
// ============================================================================

/// E6 — what kind of source change invalidated a snapshot. Mirrors the roadmap's
/// "recomputed on GradePublished / GradeRevised / coefficient change".
enum SnapshotTriggerReason {
  grade_published
  grade_revised
  coefficient_changed
  manual_rebuild
  backfill
}

/// E6 — lifecycle of a recompute dirty-row in the durable backlog.
enum SnapshotTriggerStatus {
  pending
  processing
  done
  failed
}

/// E6 — materialised per-(student × subject × term) average. A disposable CACHE
/// over published/revised Grade rows. A null termId row is the year-level roll-up
/// across all terms. `computedAt` + `sourceEventId` + `revision` power the
/// dashboard freshness signal. Recomputed by the worker on the snapshot triggers.
model StudentSubjectSnapshot {
  id             String  @id @default(uuid()) @db.Uuid
  tenantId       String  @map("tenant_id") @db.Uuid
  schoolId       String  @map("school_id") @db.Uuid
  academicYearId String  @map("academic_year_id") @db.Uuid
  studentId      String  @map("student_id") @db.Uuid
  classSectionId String  @map("class_section_id") @db.Uuid
  subjectId      String  @map("subject_id") @db.Uuid
  termId         String? @map("term_id") @db.Uuid

  average     Decimal? @db.Decimal(5, 2)
  coefficient Decimal  @default(1.0) @db.Decimal(4, 2)
  gradeCount  Int      @default(0) @map("grade_count")
  classRank   Int?     @map("class_rank")
  classSize   Int      @default(0) @map("class_size")
  trendDelta  Decimal? @map("trend_delta") @db.Decimal(5, 2)

  computedAt    DateTime @default(now()) @map("computed_at") @db.Timestamptz(6)
  sourceEventId String?  @map("source_event_id") @db.Uuid
  revision      Int      @default(1)

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@unique([studentId, subjectId, termId])
  @@index([tenantId, academicYearId, classSectionId, subjectId])
  @@index([tenantId, studentId, academicYearId])
  @@map("student_subject_snapshot")
}

/// E6 — materialised per-(student × term) GLOBAL average (coefficient-weighted
/// across subjects). Backs the parent-dashboard hero KPIs + global rank. Cascaded
/// from the per-subject snapshots in the same recompute transaction (never drifts).
model StudentGlobalSnapshot {
  id             String  @id @default(uuid()) @db.Uuid
  tenantId       String  @map("tenant_id") @db.Uuid
  schoolId       String  @map("school_id") @db.Uuid
  academicYearId String  @map("academic_year_id") @db.Uuid
  studentId      String  @map("student_id") @db.Uuid
  classSectionId String  @map("class_section_id") @db.Uuid
  termId         String? @map("term_id") @db.Uuid

  globalAverage    Decimal? @map("global_average") @db.Decimal(5, 2)
  classAverage     Decimal? @map("class_average") @db.Decimal(5, 2)
  classRank        Int?     @map("class_rank")
  classSize        Int      @default(0) @map("class_size")
  progressionDelta Decimal? @map("progression_delta") @db.Decimal(5, 2)
  attendanceRate   Decimal? @map("attendance_rate") @db.Decimal(5, 2)
  subjectCount     Int      @default(0) @map("subject_count")

  computedAt    DateTime @default(now()) @map("computed_at") @db.Timestamptz(6)
  sourceEventId String?  @map("source_event_id") @db.Uuid
  revision      Int      @default(1)

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@unique([studentId, termId])
  @@index([tenantId, academicYearId, classSectionId])
  @@index([tenantId, studentId, academicYearId])
  @@map("student_global_snapshot")
}

/// E6 — materialised per-(classSection × subject × term) distribution + class
/// average. Backs the admin drill-down + teacher-reports distribution charts and
/// the parent "moyenne de classe" context. Disposable cache over the class grades.
model ClassSubjectDistribution {
  id             String  @id @default(uuid()) @db.Uuid
  tenantId       String  @map("tenant_id") @db.Uuid
  schoolId       String  @map("school_id") @db.Uuid
  academicYearId String  @map("academic_year_id") @db.Uuid
  classSectionId String  @map("class_section_id") @db.Uuid
  subjectId      String  @map("subject_id") @db.Uuid
  termId         String? @map("term_id") @db.Uuid

  average      Decimal? @db.Decimal(5, 2)
  median       Decimal? @db.Decimal(5, 2)
  minScore     Decimal? @map("min_score") @db.Decimal(5, 2)
  maxScore     Decimal? @map("max_score") @db.Decimal(5, 2)
  countLow     Int      @default(0) @map("count_low")
  countMid     Int      @default(0) @map("count_mid")
  countHigh    Int      @default(0) @map("count_high")
  passRate     Decimal? @map("pass_rate") @db.Decimal(5, 2)
  gradeCount   Int      @default(0) @map("grade_count")
  studentCount Int      @default(0) @map("student_count")

  computedAt    DateTime @default(now()) @map("computed_at") @db.Timestamptz(6)
  sourceEventId String?  @map("source_event_id") @db.Uuid
  revision      Int      @default(1)

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@unique([classSectionId, subjectId, termId])
  @@index([tenantId, academicYearId, classSectionId])
  @@index([tenantId, schoolId, academicYearId])
  @@map("class_subject_distribution")
}

/// E6 — append-enqueue "dirty" marker. The worker cron drains pending rows per
/// tenant (FIFO, bounded batch), recomputes the affected snapshot scope, and marks
/// the row done/failed — mirroring the alerts-cron / notifications-digest poll-drain
/// pattern WITHOUT depending on the (unbuilt) outbox→BullMQ listener. Idempotent: a
/// coalescing unique key collapses a burst of dirties for the same still-pending
/// scope into ONE pending row. All scope ids are plain @db.Uuid (transient work
/// item, not a domain aggregate — no FK relation, routinely aged out).
model SnapshotRecomputeTrigger {
  id       String                @id @default(uuid()) @db.Uuid
  tenantId String                @map("tenant_id") @db.Uuid
  schoolId String?               @map("school_id") @db.Uuid
  reason   SnapshotTriggerReason
  status   SnapshotTriggerStatus @default(pending)

  studentId      String? @map("student_id") @db.Uuid
  classSectionId String? @map("class_section_id") @db.Uuid
  subjectId      String? @map("subject_id") @db.Uuid
  termId         String? @map("term_id") @db.Uuid
  academicYearId String? @map("academic_year_id") @db.Uuid

  coalesceKey String @map("coalesce_key")

  attempts    Int       @default(0)
  lastError   String?   @map("last_error")
  enqueuedAt  DateTime  @default(now()) @map("enqueued_at") @db.Timestamptz(6)
  processedAt DateTime? @map("processed_at") @db.Timestamptz(6)

  @@unique([tenantId, coalesceKey, status])
  @@index([tenantId, status, enqueuedAt])
  @@map("snapshot_recompute_trigger")
}

// ===========================================================================
// E7 — Remediation & Tutoring loop
//
// Closes the cahier's action loop: an alert's recommendation promotes into a
// RemediationPlan, the parent books a school-curated tutoring resource, and a
// calm progress strip measures the improvement (tying back to E3's IMPROVEMENT
// signal). Four net-new, tenant-scoped, additive (`db push`) models. S1 lands
// the WHOLE schema but ships NO booking write — the Booking/TutorAvailability
// tables exist with no write path, so there is provably no over-booking surface
// (the booking verb + the ADR-020 concurrency guard arrive in S2).
// ===========================================================================

/// E7 — what the tutoring resource is. A `teacher` tutor links a
/// TeacherProfile/UserProfile (an in-house teacher offering support); `external`
/// is a named partner with no platform account; `peer` is a peer-tutoring
/// programme. Display + filtering only — NO new Keycloak role.
enum TutorType {
  teacher
  external
  peer
}

/// E7 — the COST LABEL of a tutor (display-only — NEVER a price; ADR-018 finance
/// isolation). `paid_offline` = a paid tutor settled OUTSIDE the platform; E7
/// stores no money.
enum TutorCostKind {
  free
  volunteer
  paid_offline
}

/// E7 — recurrence shape of an availability slot. `recurring_weekly` = a
/// weekday+time that repeats (the parent books a dated instance of it);
/// `one_off` = a single dated datetime.
enum AvailabilityKind {
  recurring_weekly
  one_off
}

/// E7 — lifecycle of a RemediationPlan. `open` = the parent is actively pursuing
/// support; `met` = the objective was reached (kind, reversible); `closed` =
/// parent/admin closed it. NEVER deleted — the append-only AuditLog carries the
/// history.
enum RemediationPlanStatus {
  open
  met
  closed
}

/// E7 — booking state machine (mirrors MeetingRequestStatus discipline). A
/// parent books (`requested`); the tutor/teacher confirms (`confirmed`) -> the
/// session happens (`completed`); or the parent cancels (`cancelled`), or the
/// tutor declines (`declined`) or proposes another slot (`proposed_alternative`).
/// A small, auditable, append-only machine. The write paths arrive in S2.
enum BookingStatus {
  requested
  confirmed
  completed
  cancelled
  declined
  proposed_alternative
}

/// E7 — a tutoring resource curated by the school admin. Parents discover only
/// `published` tutors of their tenant, filtered to the subject. A teacher tutor
/// links a TeacherProfile (notify + ownership wall); external/peer tutors are
/// display-only. `costKind` is a LABEL, never a price (ADR-018). Subjects offered
/// are denormalised as an id array (display + filter) — the catalogue read
/// filters on it; a relation table is overkill for a small set.
model Tutor {
  id               String        @id @default(uuid()) @db.Uuid
  tenantId         String        @map("tenant_id") @db.Uuid
  schoolId         String        @map("school_id") @db.Uuid
  type             TutorType
  costKind         TutorCostKind @default(free) @map("cost_kind")
  /// Display name (the teacher or partner name, "Tutorat entre pairs — 3e").
  displayName      String        @map("display_name")
  /// Short public blurb shown in the catalogue card (kind, non-stigmatising).
  blurb            String?
  /// Subjects this tutor offers support in (Subject ids). The catalogue read filters on this.
  subjectIds       String[]      @map("subject_ids") @db.Uuid
  /// For a `teacher` tutor: the linked teacher (notify target + ownership wall). Null otherwise.
  teacherProfileId String?       @map("teacher_profile_id") @db.Uuid
  userProfileId    String?       @map("user_profile_id") @db.Uuid
  /// Only published tutors are discoverable by parents. Admin toggles this.
  published        Boolean       @default(false)
  createdBy        String        @map("created_by") @db.Uuid
  createdAt        DateTime      @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt        DateTime      @updatedAt @map("updated_at") @db.Timestamptz(6)

  school         School              @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  teacherProfile TeacherProfile?     @relation(fields: [teacherProfileId], references: [id], onDelete: SetNull)
  user           UserProfile?        @relation("TutorUser", fields: [userProfileId], references: [id], onDelete: SetNull)
  availabilities TutorAvailability[]
  bookings       Booking[]

  @@index([tenantId, schoolId, published])
  @@index([tenantId, teacherProfileId])
  @@map("tutor")
}

/// E7 — a bookable availability slot for a Tutor. `recurring_weekly` repeats on
/// `weekday` at `startTime`; `one_off` is a single `startsAt`/`endsAt`.
/// `capacity` (default 1) is the number of seats — the concurrency guard (S2 /
/// ADR-020) rejects a booking that would exceed it. Published/active slots only
/// are discoverable; a closed slot keeps its bookings (history). S1 reads slots
/// into the catalogue (no booking write).
model TutorAvailability {
  id        String           @id @default(uuid()) @db.Uuid
  tenantId  String           @map("tenant_id") @db.Uuid
  schoolId  String           @map("school_id") @db.Uuid
  tutorId   String           @map("tutor_id") @db.Uuid
  kind      AvailabilityKind
  /// recurring_weekly: 0=Mon … 6=Sun (null for one_off).
  weekday   Int?
  /// recurring_weekly: "HH:mm" local school time (null for one_off).
  startTime String?          @map("start_time")
  endTime   String?          @map("end_time")
  /// one_off: the concrete datetimes (null for recurring_weekly).
  startsAt  DateTime?        @map("starts_at") @db.Timestamptz(6)
  endsAt    DateTime?        @map("ends_at") @db.Timestamptz(6)
  /// Number of seats. The capacity guard (S2) rejects an over-capacity booking (default 1).
  capacity  Int              @default(1)
  /// Soft-close a slot without deleting it (its bookings + history survive).
  active    Boolean          @default(true)
  createdBy String           @map("created_by") @db.Uuid
  createdAt DateTime         @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime         @updatedAt @map("updated_at") @db.Timestamptz(6)

  school   School    @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  tutor    Tutor     @relation(fields: [tutorId], references: [id], onDelete: Cascade)
  bookings Booking[]

  @@index([tenantId, tutorId, active])
  @@index([tenantId, schoolId, startsAt])
  @@map("tutor_availability")
}

/// E7 — a support plan promoted from an alert's recommendation. One OPEN plan per
/// (tenant, student, subject) — the @@unique makes "promote this alert into a
/// plan" idempotent (a second promote reuses the open plan), exactly the
/// MeetingRequest discipline. Status-neutral on the alert (the plan is additive;
/// the alert lifecycle is untouched). `baselineAvg`/`baselineTrendDelta` capture
/// the subject figure at promotion time (from the E6 snapshot, live fall-through)
/// — the baseline the S3 progress strip frames the trend against. NEVER deleted.
model RemediationPlan {
  id                 String                @id @default(uuid()) @db.Uuid
  tenantId           String                @map("tenant_id") @db.Uuid
  schoolId           String?               @map("school_id") @db.Uuid
  studentId          String                @map("student_id") @db.Uuid
  subjectId          String                @map("subject_id") @db.Uuid
  /// The alert this plan was promoted from (the diagnosis). SetNull — a
  /// deleted/resolved alert doesn't delete the plan the parent is acting on.
  alertId            String?               @map("alert_id") @db.Uuid
  status             RemediationPlanStatus @default(open)
  /// Kind, non-stigmatising objective ("Rattraper les bases en mathématiques ce trimestre").
  objective          String?
  /// The subject average captured at promotion time (the strip's baseline). Nullable
  /// when no published grade exists yet (the strip shows "en attente des prochaines notes").
  baselineAvg        Decimal?              @map("baseline_avg") @db.Decimal(5, 2)
  /// The subject trend delta captured at promotion time (signed, /20), or null.
  baselineTrendDelta Decimal?              @map("baseline_trend_delta") @db.Decimal(5, 2)
  /// The parent UserProfile that created the plan (audit actorId parity).
  createdBy          String                @map("created_by") @db.Uuid
  /// Set when status flips to met/closed (kind, reversible).
  closedAt           DateTime?             @map("closed_at") @db.Timestamptz(6)
  closedBy           String?               @map("closed_by") @db.Uuid
  createdAt          DateTime              @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt          DateTime              @updatedAt @map("updated_at") @db.Timestamptz(6)

  student  Student        @relation(fields: [studentId], references: [id], onDelete: Cascade)
  subject  Subject        @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  alert    AlertInstance? @relation(fields: [alertId], references: [id], onDelete: SetNull)
  creator  UserProfile    @relation("RemediationPlanCreator", fields: [createdBy], references: [id], onDelete: Cascade)
  bookings Booking[]

  /// One plan per (tenant, student, subject, status). The promote upserts on the
  /// open-status tuple => idempotent "promote this alert into a plan" while still
  /// letting closed/met historical rows coexist (Postgres treats every status as
  /// distinct). A stricter open-only partial unique is deferred (no concurrency
  /// surface in S1 — single-parent promote, P2002-safe upsert).
  @@unique([tenantId, studentId, subjectId, status])
  @@index([tenantId, studentId, status])
  @@index([tenantId, schoolId, status, createdAt])
  @@map("remediation_plan")
}

/// E7 — a parent's booking of a tutor availability slot, tracked against a
/// RemediationPlan. `sessionAt` is the CONCRETE dated instance (a recurring slot
/// resolves to a date; a one-off is its own startsAt) — the capacity guard (S2)
/// counts ACTIVE bookings per (availability, sessionAt). Idempotent: one active
/// booking per (availability, sessionAt, plan). The status machine + append-only
/// AuditLog carry the lifecycle. NO money stored (ADR-018). The WRITE PATH lands
/// in S2 (with ADR-020); S1 only stands up the table.
model Booking {
  id             String        @id @default(uuid()) @db.Uuid
  tenantId       String        @map("tenant_id") @db.Uuid
  schoolId       String?       @map("school_id") @db.Uuid
  planId         String        @map("plan_id") @db.Uuid
  tutorId        String        @map("tutor_id") @db.Uuid
  availabilityId String        @map("availability_id") @db.Uuid
  studentId      String        @map("student_id") @db.Uuid
  /// The concrete dated session instance (the capacity-guard key). For a one_off
  /// this is the slot's startsAt; for a recurring_weekly it is the booked date's
  /// resolved datetime.
  sessionAt      DateTime      @map("session_at") @db.Timestamptz(6)
  status         BookingStatus @default(requested)
  /// Optional kind note (parent ask / tutor proposed-alternative note). Free text, reversible.
  note           String?
  /// The parent UserProfile that booked (audit actorId parity + the guardianship wall).
  bookedBy       String        @map("booked_by") @db.Uuid
  /// Set on confirm/decline/cancel/complete (who + when), append-only audit alongside.
  decidedBy      String?       @map("decided_by") @db.Uuid
  decidedAt      DateTime?     @map("decided_at") @db.Timestamptz(6)
  createdAt      DateTime      @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime      @updatedAt @map("updated_at") @db.Timestamptz(6)

  plan         RemediationPlan   @relation(fields: [planId], references: [id], onDelete: Cascade)
  tutor        Tutor             @relation(fields: [tutorId], references: [id], onDelete: Cascade)
  availability TutorAvailability @relation(fields: [availabilityId], references: [id], onDelete: Cascade)
  student      Student           @relation(fields: [studentId], references: [id], onDelete: Cascade)
  booker       UserProfile       @relation("BookingBooker", fields: [bookedBy], references: [id], onDelete: Cascade)

  /// Idempotent booking — one row per (availability, sessionAt, plan). A
  /// double-tap of the SAME slot instance for the SAME plan collapses (P2002-safe).
  /// This does NOT by itself enforce capacity across DIFFERENT plans — that is the
  /// concurrency guard (the partial unique on active status + the transactional
  /// count check), the subject of ADR-020 (S2).
  ///
  /// E7-S2 / ADR-020 — the capacity-1 over-book guard is a RAW PARTIAL UNIQUE INDEX
  /// (Prisma @@unique cannot express a WHERE), applied alongside `db push`:
  ///   CREATE UNIQUE INDEX IF NOT EXISTS booking_active_instance_unique
  ///     ON booking (availability_id, session_at)
  ///     WHERE status IN ('requested','confirmed');
  /// Canonical artifact: apps/api/prisma/sql/booking-active-instance-uniq.sql;
  /// applied idempotently on API boot by BookingIndexBootstrap. For capacity>1 the
  /// transactional SELECT … FOR UPDATE count in BookingService is the sole authority.
  @@unique([availabilityId, sessionAt, planId])
  @@index([tenantId, tutorId, status, sessionAt])
  @@index([tenantId, planId, status])
  @@index([availabilityId, sessionAt, status])
  @@map("booking")
}
