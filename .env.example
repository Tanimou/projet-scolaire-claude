# =============================================================================
# Pilotage Scolaire — env example
# Copier en .env (jamais commité). Toutes ces valeurs sont des défauts dev.
# =============================================================================

# ---- Ports exposés ----
WEB_PORT=3000
API_PORT=4000
POSTGRES_PORT=5432
REDIS_PORT=6379
KEYCLOAK_PORT=8080
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001
MAILDEV_SMTP_PORT=1025
MAILDEV_WEB_PORT=1080
JAEGER_UI_PORT=16686

# ---- Database (Postgres 15) ----
DATABASE_URL=postgresql://pilotage:pilotage@localhost:5432/pilotage?schema=public
DATABASE_URL_APP=postgresql://app_user:app_user@localhost:5432/pilotage?schema=public

# ---- Redis ----
REDIS_URL=redis://localhost:6379

# ---- Keycloak ----
KEYCLOAK_URL=http://localhost:8080
KEYCLOAK_REALM=pilotage-scolaire
KEYCLOAK_ADMIN_CLIENT_ID=portal-admin
KEYCLOAK_ADMIN_CLIENT_SECRET=change-me-portal-admin
KEYCLOAK_TEACHER_CLIENT_ID=portal-teacher
KEYCLOAK_TEACHER_CLIENT_SECRET=change-me-portal-teacher
KEYCLOAK_PARENT_CLIENT_ID=portal-parent
KEYCLOAK_PARENT_CLIENT_SECRET=change-me-portal-parent
KEYCLOAK_API_CLIENT_ID=api-backend
KEYCLOAK_API_CLIENT_SECRET=change-me-api-backend

# ---- S3 / MinIO ----
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_BUCKET=pilotage
S3_PUBLIC_BUCKET=pilotage-public
S3_ACCESS_KEY=minio
S3_SECRET_KEY=miniominio

# ---- Mail (dev: Maildev, prod: Resend/SendGrid) ----
MAIL_HOST=localhost
MAIL_PORT=1025
MAIL_FROM="Pilotage scolaire <no-reply@pilotage.local>"
RESEND_API_KEY=
# Web origin used by the worker to absolutise notification-email deep links.
WEB_PUBLIC_URL=http://localhost:3000

# ---- Observability ----
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
OTEL_SERVICE_NAME=pilotage-api
LOG_LEVEL=debug

# ---- Frontend (Next.js public env) ----
NEXT_PUBLIC_API_URL=http://localhost:4000
NEXT_PUBLIC_KEYCLOAK_URL=http://localhost:8080
NEXT_PUBLIC_KEYCLOAK_REALM=pilotage-scolaire
NEXT_PUBLIC_DEFAULT_LOCALE=fr-FR

# ---- App ----
NODE_ENV=development
APP_BASE_URL=http://localhost:3000
SESSION_SECRET=change-me-a-very-long-random-string-min-32-chars
# NextAuth/Auth.js session-signing secret (REQUIRED by the web app — without it
# every /api/auth/* request 500s with MissingSecret). Min 32 chars in prod.
AUTH_SECRET=change-me-a-very-long-random-string-min-32-chars
WEBPUSH_VAPID_PUBLIC=
WEBPUSH_VAPID_PRIVATE=
WEBPUSH_VAPID_SUBJECT=mailto:contact@pilotage.local
