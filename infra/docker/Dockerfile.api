# syntax=docker/dockerfile:1.7
# ------------------------------------------------------------------------------
# NestJS API — multi-stage build (deps → build → runtime)
# ------------------------------------------------------------------------------
ARG NODE_VERSION=22.13.1
ARG PNPM_VERSION=9.12.3

# ---------- 1) Base image with pnpm ----------
FROM node:${NODE_VERSION}-alpine AS base
ARG PNPM_VERSION
ENV PNPM_HOME=/pnpm \
    PATH=/pnpm:$PATH \
    CI=true
RUN corepack enable && corepack prepare pnpm@${PNPM_VERSION} --activate
RUN apk add --no-cache libc6-compat openssl curl tini
WORKDIR /app

# ---------- 2) Install dependencies ----------
FROM base AS deps
COPY pnpm-lock.yaml pnpm-workspace.yaml package.json turbo.json ./
COPY apps/api/package.json apps/api/package.json
COPY apps/worker/package.json apps/worker/package.json
COPY packages/contracts/package.json packages/contracts/package.json
COPY packages/tsconfig/package.json packages/tsconfig/package.json
COPY packages/eslint-config/package.json packages/eslint-config/package.json
RUN --mount=type=cache,id=pnpm-store,target=/pnpm/store \
    pnpm install --frozen-lockfile

# ---------- 3) Build ----------
FROM deps AS build
COPY . .
# Generate Prisma client + build api
RUN pnpm --filter @pilotage/contracts build
# `exec` is required: `pnpm --filter X prisma …` looks for a "prisma" SCRIPT,
# finds none, and silently no-ops (exit 0) — leaving the client ungenerated and
# every Prisma result typed `any`. `exec` runs the prisma binary instead.
RUN pnpm --filter @pilotage/api exec prisma generate
RUN pnpm --filter @pilotage/api build
# Prune dev deps for runtime
RUN pnpm --filter @pilotage/api deploy --prod /prod/api
# `pnpm deploy --prod` prunes the prisma CLI (a devDependency) and ships
# @prisma/client WITHOUT its generated client. Re-materialise the client
# directly inside the pruned tree, using the prisma CLI from the build stage
# (cwd=/prod/api so it resolves the deployed @prisma/client). The native engine
# target is linux-musl — identical alpine in build and runtime stages.
RUN mkdir -p /prod/api/prisma && cp -rf /app/apps/api/prisma/. /prod/api/prisma/ \
 && cd /prod/api \
 && /app/apps/api/node_modules/.bin/prisma generate --schema=prisma/schema.prisma

# ---------- 4) Runtime ----------
FROM node:${NODE_VERSION}-alpine AS runtime
RUN apk add --no-cache libc6-compat openssl curl tini && \
    addgroup -S app && adduser -S app -G app
WORKDIR /app

# Copy runtime artefacts
COPY --from=build --chown=app:app /prod/api ./
COPY --from=build --chown=app:app /app/apps/api/prisma ./prisma

ENV NODE_ENV=production \
    PORT=4000 \
    NODE_OPTIONS="--enable-source-maps"

USER app
EXPOSE 4000

HEALTHCHECK --interval=15s --timeout=3s --start-period=20s --retries=5 \
  CMD curl -fsS http://localhost:4000/healthz || exit 1

ENTRYPOINT ["/sbin/tini", "--"]
CMD ["node", "dist/main.js"]
