# =============================================================================
# Pilotage Scolaire — PRODUCTION env (template). Copy to .env.prod (gitignored)
# and fill the secrets. Consumed by scripts/deploy-prod.sh +
# infra/docker-compose.prod.yml. Browser-facing URLs MUST be the real origin.
# =============================================================================

# ---- Public origin (served by the host's Traefik over TLS) ----
PUBLIC_BASE_URL=https://pilotage.srv861861.hstgr.cloud
PUBLIC_HOST=pilotage.srv861861.hstgr.cloud

# ---- NextAuth/Auth.js session-signing secret (generate: openssl rand -hex 32) ----
AUTH_SECRET=__CHANGE_ME__min_32_chars__

# ---- Demo seed password for the provisioned Keycloak demo users ----
KEYCLOAK_DEMO_PASSWORD=Demo!2024Pilotage

# ---- Infra host-port bindings ----
# CRITICAL on this VPS: the firewall is OPEN, so every infra port is bound to
# 127.0.0.1 ONLY. Containers still talk over the internal docker network by
# service name; these host bindings are just for local debugging. nginx is NOT
# published to the host at all in prod — Traefik reaches it over `root_web`.
POSTGRES_PORT=127.0.0.1:5432
REDIS_PORT=127.0.0.1:6379
KEYCLOAK_PORT=127.0.0.1:8080
MINIO_PORT=127.0.0.1:9000
MINIO_CONSOLE_PORT=127.0.0.1:9001
MAILDEV_SMTP_PORT=127.0.0.1:1025
MAILDEV_WEB_PORT=127.0.0.1:1080
API_PORT=127.0.0.1:4000
WEB_PORT=127.0.0.1:3000
# nginx host ports — unused in prod (Traefik fronts it) but parametrised so they
# never collide with Traefik's 80/443. Bound to localhost as harmless no-ops.
HTTP_PORT=127.0.0.1:8090
HTTPS_PORT=127.0.0.1:8453
