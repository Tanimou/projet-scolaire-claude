{
  "name": "@pilotage/contracts",
  "version": "0.0.0",
  "private": true,
  "license": "UNLICENSED",
  "main": "./dist/index.js",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./dist/index.js"
    },
    "./enums": {
      "types": "./src/enums/index.ts",
      "default": "./dist/enums/index.js"
    },
    "./dto": {
      "types": "./src/dto/index.ts",
      "default": "./dist/dto/index.js"
    },
    "./events": {
      "types": "./src/events/index.ts",
      "default": "./dist/events/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@pilotage/eslint-config": "workspace:*",
    "@pilotage/tsconfig": "workspace:*",
    "typescript": "^5.6.3"
  }
}
